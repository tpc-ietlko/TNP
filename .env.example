# SMTP config for nodemailer (use an SMTP provider or Gmail App Passwords)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Optional; defaults to SMTP_USER
SMTP_FROM=no-reply@example.com

# Where form submissions should be delivered
CONTACT_RECEIVER_EMAIL=tnp@example.com
